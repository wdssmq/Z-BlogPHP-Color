{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch grammar",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": {
            "regexp": "^(npm ERR!.*|.*(?:Error|ERROR|Error:).*)$",
            "message": 1
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "^Watching \".*\" \\.\\.$"
          }
        }
      ]
    }
  ]
}
